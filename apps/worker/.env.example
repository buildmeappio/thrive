# Master DB — same connection used by central-web
MASTER_DATABASE_URL=postgresql://postgres:postgres@localhost:5442/master_db

# Shared secret for /enqueue-provision — must match central-web WORKER_ENQUEUE_SECRET
WORKER_ENQUEUE_SECRET=

# HTTP port for job enqueue endpoint (central-web calls POST /enqueue-provision)
WORKER_HTTP_PORT=3004
