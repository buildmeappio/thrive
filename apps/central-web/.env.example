# App
NEXT_PUBLIC_APP_URL=http://localhost:3003
PORTAL_DOMAIN=localhost:3003

# Admin app redirect template — {slug} is replaced at runtime
ADMIN_APP_URL_TEMPLATE=http://{slug}.localhost:3000/admin

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3003

# Keycloak (central-web client — separate from admin-web client)
KEYCLOAK_ISSUER=http://localhost:8080/realms/Thrive
KEYCLOAK_CLIENT_ID=central-web
KEYCLOAK_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Master DB (same instance as other apps, port 5442 locally)
MASTER_DATABASE_URL=postgresql://postgres:postgres@localhost:5442/master_db

# Worker — provision job enqueue endpoint (default port 3004)
WORKER_URL=http://localhost:3004
# Shared secret — must match worker WORKER_ENQUEUE_SECRET (used in Authorization: Bearer)
WORKER_ENQUEUE_SECRET=

# AWS S3 (shared bucket with admin-web)
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_REGION=ca-central-1
AWS_S3_BUCKET_NAME=dev-thrive-portal-564083281173
