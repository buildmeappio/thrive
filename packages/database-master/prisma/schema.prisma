generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  keycloakSub   String?   @unique @map("keycloak_sub") @db.VarChar(255)
  firstName     String?   @map("first_name") @db.VarChar(255)
  lastName      String?   @map("last_name") @db.VarChar(255)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("verifications")
}

model Tenant {
  id                      String         @id @default(uuid()) @db.Uuid
  subdomain               String         @unique @map("subdomain") @db.VarChar(63)
  name                    String         @map("name") @db.VarChar(255)
  status                  TenantStatus   @default(DRAFT) @map("status")
  databaseName            String         @default("") @map("database_name") @db.VarChar(63)
  logoUrl                 String?        @map("logo_url")
  stripeCheckoutSessionId String?        @unique @map("stripe_checkout_session_id") @db.VarChar(255)
  provisionStep           ProvisionStep? @map("provision_step")
  provisionErrorMessage   String?        @map("provision_error_message")
  createdAt               DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  subscription            Subscription?
  users                   TenantUser[]
  loginTickets            TenantLoginTicket[]

  @@map("tenants")
}

model TenantUser {
  id          String         @id @default(uuid()) @db.Uuid
  keycloakSub String         @map("keycloak_sub") @db.VarChar(255)
  tenantId    String         @map("tenant_id") @db.Uuid
  role        TenantUserRole @default(TENANT_USER) @map("role")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([keycloakSub, tenantId])
  @@index([keycloakSub])
  @@index([tenantId])
  @@map("tenant_users")
}

model TenantLoginTicket {
  id          String         @id @default(uuid()) @db.Uuid
  ticketHash  String         @unique @map("ticket_hash") @db.VarChar(64)
  tenantId    String         @map("tenant_id") @db.Uuid
  keycloakSub String         @map("keycloak_sub") @db.VarChar(255)
  role        TenantUserRole @map("role")
  nextPath    String         @map("next_path")
  expiresAt   DateTime       @map("expires_at") @db.Timestamptz(6)
  consumedAt  DateTime?      @map("consumed_at") @db.Timestamptz(6)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@map("tenant_login_tickets")
}

model Plan {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String   @db.VarChar(255)
  description          String?
  priceMonthly         Decimal  @map("price_monthly") @db.Decimal(10, 2)
  priceYearly          Decimal? @map("price_yearly") @db.Decimal(10, 2)
  stripeProductId      String?  @map("stripe_product_id") @db.VarChar(255)
  stripeMonthlyPriceId String?  @map("stripe_monthly_price_id") @db.VarChar(255)
  stripeYearlyPriceId  String?  @map("stripe_yearly_price_id") @db.VarChar(255)
  features             Json
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  tenantId             String             @unique @map("tenant_id") @db.Uuid
  stripePriceId        String?            @map("stripe_price_id") @db.VarChar(255)
  stripeSubscriptionId String?            @map("stripe_subscription_id") @db.VarChar(255)
  stripeCustomerId     String?            @map("stripe_customer_id") @db.VarChar(255)
  status               SubscriptionStatus @default(ACTIVE) @map("status")
  currentPeriodEnd     DateTime?          @map("current_period_end") @db.Timestamptz(6)
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}


/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model agenda_jobs {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String    @unique(map: "agenda_jobs_single_job_idx", where: raw("((type)::text = 'single'::text)")) @db.VarChar(255)
  priority            Int       @default(0)
  next_run_at         DateTime? @db.Timestamptz(6)
  type                String    @default("normal") @db.VarChar(10)
  locked_at           DateTime? @db.Timestamptz(6)
  last_finished_at    DateTime? @db.Timestamptz(6)
  failed_at           DateTime? @db.Timestamptz(6)
  fail_count          Int?
  fail_reason         String?
  repeat_timezone     String?   @db.VarChar(100)
  last_run_at         DateTime? @db.Timestamptz(6)
  repeat_interval     String?   @db.VarChar(255)
  data                Json?     @default("{}")
  repeat_at           String?   @db.VarChar(255)
  disabled            Boolean?  @default(false)
  progress            Float?    @db.Real
  fork                Boolean?  @default(false)
  last_modified_by    String?   @db.VarChar(255)
  debounce_started_at DateTime? @db.Timestamptz(6)
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)

  @@index([name, next_run_at, priority(sort: Desc), locked_at, disabled], map: "agenda_jobs_find_and_lock_idx", where: raw("(disabled = false)"))
  @@index([locked_at], where: raw("(locked_at IS NOT NULL)"))
  @@index([next_run_at], where: raw("(next_run_at IS NOT NULL)"))
}

model agenda_logs {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp     DateTime @default(now()) @db.Timestamptz(6)
  level         String   @db.VarChar(10)
  event         String   @db.VarChar(30)
  job_id        String?  @db.VarChar(255)
  job_name      String   @db.VarChar(255)
  message       String
  duration      Int?
  error         String?
  fail_count    Int?
  retry_delay   Int?
  retry_attempt Int?
  agenda_name   String?  @db.VarChar(255)
  meta          Json?

  @@index([job_id, timestamp(sort: Desc)], map: "agenda_logs_job_id_idx")
  @@index([job_name, timestamp(sort: Desc)], map: "agenda_logs_job_name_idx")
  @@index([timestamp(sort: Desc)])
}

enum TenantStatus {
  DRAFT
  PENDING
  ACTIVE
  SUSPENDED
}

enum ProvisionStep {
  CREATING_DB
  RUNNING_MIGRATIONS
  CREATING_ADMIN
  DONE
}

enum TenantUserRole {
  PLATFORM_ADMIN
  TENANT_ADMIN
  TENANT_USER
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}
