{
  "realm": "thrive",
  "enabled": true,
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "clients": [
    {
      "clientId": "admin-web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "admin-web-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://auth.localhost:3000/api/auth/oauth2/callback/keycloak",
        "http://localhost:3000/api/auth/oauth2/callback/keycloak"
      ],
      "webOrigins": [
        "http://auth.localhost:3000",
        "http://localhost:3000",
        "http://*.localhost:3000"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/admin/login"
      }
    },
    {
      "clientId": "examiner-web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "examiner-web-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3001/examiner/api/auth/callback/keycloak",
        "http://localhost:3001/*"
      ],
      "webOrigins": ["http://localhost:3001"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3001/examiner/login"
      }
    },
    {
      "clientId": "organization-web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "organization-web-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3002/organization/api/auth/callback/keycloak",
        "http://localhost:3002/*"
      ],
      "webOrigins": ["http://localhost:3002"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3002/organization/login"
      }
    },
    {
      "clientId": "central-web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "central-web-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:3003/api/auth/callback/keycloak",
        "http://localhost:3003/*"
      ],
      "webOrigins": ["http://localhost:3003"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3003,http://localhost:3003/login"
      }
    }
  ]
}
